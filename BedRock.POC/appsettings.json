{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Aws": {
    "Region": "us-east-1",
    "S3BucketName": "YOUR-S3-BUCKET-NAME"
  },
  "Textract": {
    "PollingIntervalSeconds": 3,
    "MaxPollingAttempts": 60
  },
  "Bedrock": {
    "DefaultPromptTemplate": "<System>\nExtract keys from the document and return a JSON array of objects: {\"key\":string,\"value\":string,\"startPosition\":int,\"score\":1-100}.\nKeys: {keyList}\nIf not found: set value=\"\" and startPosition=-1.\nIf multiple values for a key: include multiple objects with the same key.\nReturn only valid JSON (no explanation or extra text).\n</system>",
    "Models": {
      "Claude35Sonnet": {
        "ModelId": "anthropic.claude-3-sonnet-20240229-v1:0",
        "Temperature": 0.5,
        "TopP": 0.9
      },
      "CommandLight": {
        "ModelId": "cohere.command-light-text-v14",
        "Temperature": 0.7,
        "TopP": 0.9
      }
    }
  },
  "Extraction": {
    "DefaultKeys": [
      "First Party", "Second Party",
      "Acknowledgement Date", "Consideration 1", "Consideration 2", "Filing Date", "Name Count",
      "Notes", "Return Name", "Return Address Line 1", "Return Address Line 2", "Return City",
      "Return Zip", "Return State",
      "Case Number", "Parcel ID", "Lot", "Block", "Subdivision",
      "Apt", "Condo", "Building", "Land Lot", "Township", "Tract",
      "Unit", "Week", "District", "City", "Zip",
      "Folio Number", "Folio Type", "Property Section", "Range", "Section",
      "Street Name", "Street Suffix", "Street Direction", "Address Line 1", "Address Line 2",
      "Comment", "Period", "Plat Book", "Plat Page",
      "Related Document"
    ]
  }
}
